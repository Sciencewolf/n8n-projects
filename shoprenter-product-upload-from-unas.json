    {
      "parameters": {
        "jsCode": "const products = $input.all();\nconst sheetItems = $('category dict').all();\n\n\n/**\n * Build: reflexshop category -> id\n */\nconst categoryMap = {};\n\nfor (const row of sheetItems) {\n  const source = row.json.unas_shop?.trim();\n  const target = row.json.id?.trim();\n\n  if (source && target && target !== '0') {\n    categoryMap[source] = target;\n  }\n}\n\nif (Object.keys(categoryMap).length === 0) {\n  throw new Error('Category map is EMPTY – check sheet headers (reflexshop / id)');\n}\n\n/**\n * Extract ONLY alternative category fields\n */\nfunction extractProductCategories(data) {\n  return Object.keys(data)\n    .filter(key => key.startsWith('Alternatív Kategória'))\n    .map(key => data[key]?.trim())\n    .filter(Boolean);\n}\n\nconst output = [];\nlet skippedNoAltCategory = 0;\nlet skippedNoMapping = 0;\n\nfor (const item of products) {\n  const data = JSON.parse(JSON.stringify(item.json)); // safe clone\n\n  const altCategories = extractProductCategories(data);\n\n  if (altCategories.length === 0) {\n    skippedNoAltCategory++;\n    continue;\n  }\n\n  const mappedCategoryIds = altCategories\n    .filter(cat => {\n      if (!categoryMap[cat]) {\n        return false;\n      }\n      return true;\n    })\n    .map(cat => categoryMap[cat])\n    .filter((id, i, arr) => arr.indexOf(id) === i); // unique\n\n  if (mappedCategoryIds.length === 0) {\n    skippedNoMapping++;\n    continue;\n  }\n\n  data.categories = mappedCategoryIds;\n\n  delete data.Kategória;\n  Object.keys(data)\n    .filter(k => k.startsWith('Alternatív Kategória'))\n    .forEach(k => delete data[k]);\n\n  output.push({\n    json: {\n      webshop: 'shoprenter_shop',\n      product: data,\n    },\n  });\n}\n\nreturn output;\n"
      },
