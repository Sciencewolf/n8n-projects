        352,
        2224
      ],
      "id": "0631a3c8-f01f-4e8f-99bd-30fa274d6fef",
      "name": "upload main image into file manager"
    },
    {
      "parameters": {
        "jsCode": "const items = $('data').all();\n\nfunction slugify(str) {\n  return str\n    .toLowerCase()\n    .normalize('NFD')                 // remove accents\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9]+/g, '-')      // non-alphanum → dash\n    .replace(/^-+|-+$/g, '');         // trim dashes\n}\n\nconst output = [];\n\nfor (const item of items) {\n  const imageLinksRaw = item.json[\"Kép link\"];\n  const productName = item.json[\"Termék Név\"] || \"image\";\n\n  if (!imageLinksRaw || typeof imageLinksRaw !== \"string\") {\n    output.push({\n      json: {\n        ...item.json,\n        imageArray: []\n      }\n    });\n    continue;\n  }\n\n  const imageLinks = imageLinksRaw\n    .split(\"|\")\n    .map(l => l.trim())\n    .filter(Boolean)\n    .slice(1); // 🔥 REMOVE FIRST IMAGE\n\n  const baseName = slugify(productName);\n\n  const imageArray = imageLinks.map((url, index) => {\n    const ext = url.split(\".\").pop()?.split(\"?\")[0] || \"jpg\";\n\n    return {\n      imageUrl: url, // still a STRING\n      filename: `${baseName}-${index + 2}.${ext}` // starts from -2 (since main image is removed)\n    };\n  });\n\n  output.push({\n    json: {\n      ...item.json,\n      imageArray\n    }\n  });\n}\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1968,
        2208
      ],
