        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"filePath\": \"{{'product/' +  $('data').item.json['Cikkszám']  + '.jpg'}}\",\n  \"type\": \"image\",\n  \"attachment\": {{ $json.data.toJsonString() }}\n}\n\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
