    {
      "parameters": {
        "jsCode": "const products = $input.all();\nconst sheetItems = $('categories').all();\n\n/**\n * OLD webshop category -> NEW webshop category\n */\nconst categoryMap = {};\n\nfor (const row of sheetItems) {\n  const oldCat = row.json.unas_shop?.trim();\n  const newCat = row.json.unas_other_shop?.trim();\n\n  if (oldCat && newCat && newCat !== '0') {\n    categoryMap[oldCat] = newCat;\n  }\n}\n\nconsole.log('CategoryMap size:', Object.keys(categoryMap).length);\nconsole.log('CategoryMap sample:', Object.entries(categoryMap).slice(0, 5));\n\nif (Object.keys(categoryMap).length === 0) {\n  throw new Error('Category map is EMPTY – check sheet headers');\n}\n\nconst output = [];\nlet skippedNoMain = 0;\nlet skippedNoMapping = 0;\n\nfor (const item of products) {\n  const data = JSON.parse(JSON.stringify(item.json)); // safe clone\n\n  // ---------- MAIN CATEGORY ----------\n  const oldMain = data.Kategória?.trim();\n\n  if (!oldMain) {\n    skippedNoMain++;\n    continue;\n  }\n\n  if (!categoryMap[oldMain]) {\n    skippedNoMapping++;\n    continue;\n  }\n\n  const newMain = categoryMap[oldMain];\n  data.Kategória = newMain;\n\n  // ---------- ALTERNATIVE CATEGORIES ----------\n  const oldAltCategories = [\n    data['Alternatív Kategória 1'],\n    data['Alternatív Kategória 2'],\n    data['Alternatív Kategória 3'],\n    data['Alternatív Kategória 4'],\n    data['Alternatív Kategória 5'],\n    data['Alternatív Kategória 6'],\n    data['Alternatív Kategória 7'],\n  ];\n\n  const newAltCategories = oldAltCategories\n    .map(cat => cat?.trim())\n    .filter(cat => {\n      if (!cat) return false;\n      if (!categoryMap[cat]) {\n        return false;\n      }\n      return true;\n    })\n    .map(cat => categoryMap[cat])\n    .filter(cat => cat !== newMain)\n    .filter((cat, i, arr) => arr.indexOf(cat) === i);\n\n  for (let i = 0; i < 7; i++) {\n    data[`Alternatív Kategória ${i + 1}`] = newAltCategories[i] || '';\n  }\n\n  output.push({\n    json: {\n      webshop: 'other',\n      product: data,\n    },\n  });\n}\n\nreturn output;\n"
      },
