    {
      "parameters": {
        "jsCode": "const items = $('After AI').all();\n\nconst altCats = [\n  \"Alternatív Kategória 1\",\n  \"Alternatív Kategória 2\",\n  \"Alternatív Kategória 3\",\n  \"Alternatív Kategória 4\",\n  \"Alternatív Kategória 5\",\n  \"Alternatív Kategória 6\",\n  \"Alternatív Kategória 7\",\n];\n\nconst orderedKeys = [\n  \"Cikkszám\",\n  \"Termék Név\",\n  \"Rövid Leírás\",\n  \"Státusz\",\n  \"Nettó Ár\",\n  \"Bruttó Ár\",\n  \"Kategória\",\n  \"Kép link\",\n  ...altCats,\n];\n\nreturn items.map(item => {\n  const src = item.json;\n  const sorted = {};\n\n  for (const label of orderedKeys) {\n    const normLabel = label.toLowerCase().trim();\n\n    // keresünk olyan valós kulcsot, ami egyezik vagy tartalmazza a labelt\n    const realKey = Object.keys(src).find(k => {\n      const normKey = k.toLowerCase().trim();\n      return normKey === normLabel || normKey.includes(normLabel);\n    });\n\n    sorted[label] = realKey ? src[realKey] : \"\";\n  }\n\n  return { json: sorted };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        3264
      ],
